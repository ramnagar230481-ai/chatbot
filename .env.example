# Hugging Face model name
# Options:
# - microsoft/DialoGPT-small  (fastest, lowest RAM)
# - microsoft/DialoGPT-medium (balanced quality/speed)
# - microsoft/DialoGPT-large  (best quality, highest RAM)
MODEL_NAME=microsoft/DialoGPT-small

# Number of previous turns to keep in context
MAX_HISTORY_LENGTH=5

# Maximum user message length in characters
MAX_INPUT_LENGTH=500

# API host binding
HOST=0.0.0.0

# API port
PORT=8000

# Enable debug logging and auto-reload
DEBUG=true

# Global rate limit for general endpoints
RATE_LIMIT=20/minute

# Rate limit for chat endpoint
RATE_LIMIT_CHAT=10/minute

# Maximum newly generated tokens in each response
MAX_NEW_TOKENS=200

# Sampling temperature
TEMPERATURE=0.7

# Nucleus sampling probability
TOP_P=0.9

# Top-k sampling
TOP_K=50

# Penalize repetitive outputs
REPETITION_PENALTY=1.2

# Inference timeout in seconds
MODEL_TIMEOUT=30
